#Do not edit this file
#Copy this file,rename to .env
#Fill in your own credentials


# MongoDB
MONGO_USERNAME=your-mongodb-username-here
MONGO_PASSWORD=your-mongodb-password-here
MONGO_DATABASE=thriftdb

# JWT
JWT_SECRET=your-jwt-secret-key-minimum-64-characters
JWT_EXPIRATION=86400000

# Mail
MAIL_USERNAME=your-gmail-here
MAIL_PASSWORD=your-gmail-app-password-here

# Server
SERVER_PORT=8080

#Super Admin
SUPER_ADMIN_EMAIL=super_admin_email
SUPER_ADMIN_PASSWORD=super_admin_password
SUPER_ADMIN_FIRSTNAME=super_admin_firstName
SUPER_ADMIN_LASTNAME=super_admin_lastname

SUPPORT_WHATSAPP=your_whatsapp_number

EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key-here
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6